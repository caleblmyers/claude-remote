{
  "name": "claude-remote-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend server for Claude Remote — mobile controller for Claude Code",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^1.0.128",
    "better-sqlite3": "^12.8.0",
    "express": "^4.18.3",
    "express-rate-limit": "^8.3.1",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1",
    "web-push": "^3.6.7",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.20",
    "@types/uuid": "^9.0.7",
    "@types/web-push": "^3.6.3",
    "@types/ws": "^8.5.10",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
